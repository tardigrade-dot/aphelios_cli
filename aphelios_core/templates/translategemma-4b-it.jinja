{%- set languages = {
"zh": "Chinese",
"zh-Hans": "Simplified Chinese",
"zh-Hant": "Traditional Chinese",
"en": "English",
"ja": "Japanese",
"ko": "Korean"
} -%}
{{ bos_token }}
{%- for message in messages -%}
    {%- if message['role'] == 'user' -%}
        {# --- 核心解析逻辑 --- #}
        {%- set input_text = message.content | trim -%}
        {%- if '|' in input_text -%}
            {%- set parts = input_text.split('|') -%}
            {%- set src_code = parts[0] | trim -%}
            {%- set tgt_code = parts[1] | trim -%}
            {%- set content_text = parts[2:] | join('|') | trim -%}
        {%- else -%}
            {# 默认模式：中翻英 #}
            {%- set src_code = "zh" -%}
            {%- set tgt_code = "en" -%}
            {%- set content_text = input_text -%}
        {%- endif -%}

        {%- set src_name = languages[src_code] | default("Chinese") -%}
        {%- set tgt_name = languages[tgt_code] | default("English") -%}

        {{ '<start_of_turn>user\nYou are a professional ' + src_name + ' (' + src_code + ') to ' + tgt_name + ' (' + tgt_code + ') translator. Produce only the ' + tgt_name + ' translation.\n\n\n' + content_text + '\n\n\nTranslate the above text from ' + src_name + ' (' + src_code + ') to ' + tgt_name + ' (' + tgt_code + '). Output only the ' + tgt_name + ' translation.' + '<end_of_turn>\n' }}
    {%- elif message['role'] == 'assistant' -%}
        {{ '<start_of_turn>model\n' + message.content | trim + '<end_of_turn>\n' }}
    {%- endif -%}
{%- endfor -%}
{%- if add_generation_prompt -%}
    {{ '<start_of_turn>model\n' }}
{%- endif -%}
