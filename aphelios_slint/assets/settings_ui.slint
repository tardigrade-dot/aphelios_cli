import { Button, LineEdit } from "std-widgets.slint";

export component SettingsWindow inherits Window {
    width: 680px;
    height: 780px;
    title: "设置";
    background: #f6f6f6;
    default-font-family: "PingFang SC";

    // 属性定义
    in-out property <string> ocr_model_path;
    in-out property <string> ocr_output_dir;

    // ASR 语音识别设置
    in-out property <string> asr_model_path;
    in-out property <string> asr_aligner_model_path;
    in-out property <string> asr_vad_model_path;

    // SRT 文本对齐设置
    in-out property <string> srt_model_path;
    in-out property <string> srt_min_segment_length: "80";
    in-out property <string> srt_max_segment_length: "120";

    // TTS 设置
    in-out property <string> tts_model_path;
    in-out property <string> tts_output_path;
    in-out property <string> tts_ref_audio_path;
    in-out property <string> tts_ref_text;

    // Demucs 人声分离设置
    in-out property <string> demucs_model_path;

    // 保存状态
    in-out property <string> save_status_message: "";

    callback go_back();
    callback save_settings();
    callback select_ocr_model_path();
    callback select_ocr_output_dir();
    callback select_asr_model_path();
    callback select_asr_aligner_model_path();
    callback select_asr_vad_model_path();
    callback select_srt_model_path();
    callback select_tts_model_path();
    callback select_tts_output_path();
    callback select_tts_ref_audio();
    callback select_demucs_model_path();

    VerticalLayout {
        padding: 20px;
        spacing: 16px;
        alignment: start; // 关键：顶部对齐

        // --- 头部工具栏 ---
        HorizontalLayout {
            height: 32px;
            alignment: space-between;
            Button {
                text: "← 返回";
                width: 70px;
                clicked => {
                    root.go_back();
                }
            }

            Text {
                text: "应用偏好设置";
                font-size: 16px;
                font-weight: 700;
                vertical-alignment: center;
            }

            HorizontalLayout {
                spacing: 10px;
                alignment: center;

                if save_status_message != "": Text {
                    text: save_status_message;
                    font-size: 12px;
                    color: #52c41a;
                    vertical-alignment: center;
                }

                Button {
                    text: "💾 保存设置";
                    width: 90px;
                    primary: true;
                    enabled: save_status_message == "";
                    clicked => {
                        root.save_settings();
                    }
                }
            }
        }

        // --- 设置滚动区 (防止内容过多超出窗口) ---
        // 注意：Slint原生ScrollView需要包装，这里先用VerticalLayout模拟紧凑排布
        VerticalLayout {
            spacing: 12px;

            // 1. OCR 卡片
            Rectangle {
                background: #ffffff;
                border-radius: 8px;
                border-width: 1px;
                border-color: #e0e0e0;
                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;
                    Text {
                        text: "📝 OCR 识别设置";
                        font-weight: 700;
                        color: #333;
                    }

                    // 设置行组件化模拟
                    HorizontalLayout {
                        height: 28px;
                        spacing: 10px;
                        Text {
                            text: "模型路径";
                            width: 70px;
                            vertical-alignment: center;
                            font-size: 12px;
                            color: #1a2535;
                        }

                        LineEdit {
                            text <=> root.ocr_model_path;
                        }

                        Button {
                            text: "选择";
                            width: 50px;
                            clicked => {
                                root.select_ocr_model_path();
                            }
                        }
                    }

                    HorizontalLayout {
                        height: 28px;
                        spacing: 10px;
                        Text {
                            text: "输出目录";
                            width: 70px;
                            vertical-alignment: center;
                            font-size: 12px;
                            color: #1a2535;
                        }

                        LineEdit {
                            text <=> root.ocr_output_dir;
                        }

                        Button {
                            text: "选择";
                            width: 50px;
                            clicked => {
                                root.select_ocr_output_dir();
                            }
                        }
                    }
                }
            }

            // 2. ASR 卡片
            Rectangle {
                background: #ffffff;
                border-radius: 8px;
                border-width: 1px;
                border-color: #e0e0e0;
                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;
                    Text {
                        text: "🎤 ASR 语音识别";
                        font-weight: 700;
                        color: #333;
                    }

                    HorizontalLayout {
                        height: 28px;
                        spacing: 10px;
                        Text {
                            text: "ASR模型";
                            width: 70px;
                            vertical-alignment: center;
                            font-size: 12px;
                            color: #1a2535;
                        }

                        LineEdit {
                            text <=> root.asr_model_path;
                        }

                        Button {
                            text: "选择";
                            width: 50px;
                            clicked => {
                                root.select_asr_model_path();
                            }
                        }
                    }

                    HorizontalLayout {
                        height: 28px;
                        spacing: 10px;
                        Text {
                            text: "Aligner模型";
                            width: 70px;
                            vertical-alignment: center;
                            font-size: 12px;
                            color: #1a2535;
                        }

                        LineEdit {
                            text <=> root.asr_aligner_model_path;
                        }

                        Button {
                            text: "选择";
                            width: 50px;
                            clicked => {
                                root.select_asr_aligner_model_path();
                            }
                        }
                    }

                    HorizontalLayout {
                        height: 28px;
                        spacing: 10px;
                        Text {
                            text: "VAD模型";
                            width: 70px;
                            vertical-alignment: center;
                            font-size: 12px;
                            color: #1a2535;
                        }

                        LineEdit {
                            text <=> root.asr_vad_model_path;
                        }

                        Button {
                            text: "选择";
                            width: 50px;
                            clicked => {
                                root.select_asr_vad_model_path();
                            }
                        }
                    }
                }
            }

            // 3. SRT 文本对齐卡片
            Rectangle {
                background: #ffffff;
                border-radius: 8px;
                border-width: 1px;
                border-color: #e0e0e0;
                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;
                    Text {
                        text: "📝 SRT 文本对齐";
                        font-weight: 700;
                        color: #333;
                    }

                    HorizontalLayout {
                        height: 28px;
                        spacing: 10px;
                        Text {
                            text: "模型路径";
                            width: 70px;
                            vertical-alignment: center;
                            font-size: 12px;
                            color: #1a2535;
                        }

                        LineEdit {
                            text <=> root.srt_model_path;
                        }

                        Button {
                            text: "选择";
                            width: 50px;
                            clicked => {
                                root.select_srt_model_path();
                            }
                        }
                    }

                    HorizontalLayout {
                        height: 28px;
                        spacing: 10px;
                        Text {
                            text: "分段长度";
                            width: 70px;
                            vertical-alignment: center;
                            font-size: 12px;
                            color: #1a2535;
                        }

                        LineEdit {
                            text <=> root.srt_min_segment_length;
                            width: 60px;
                        }

                        Text {
                            text: "~";
                            vertical-alignment: center;
                            color: #1a2535;
                        }

                        LineEdit {
                            text <=> root.srt_max_segment_length;
                            width: 60px;
                        }

                        Text {
                            text: "字";
                            vertical-alignment: center;
                            color: #1a2535;
                        }
                    }
                }
            }

            // 4. TTS 卡片
            Rectangle {
                background: #ffffff;
                border-radius: 8px;
                border-width: 1px;
                border-color: #e0e0e0;
                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;
                    Text {
                        text: "🔊 TTS 语音合成";
                        font-weight: 700;
                        color: #333;
                    }

                    HorizontalLayout {
                        height: 28px;
                        spacing: 10px;
                        Text {
                            text: "模型路径";
                            width: 70px;
                            vertical-alignment: center;
                            font-size: 12px;
                            color: #1a2535;
                        }

                        LineEdit {
                            text <=> root.tts_model_path;
                        }

                        Button {
                            text: "选择";
                            width: 50px;
                            clicked => {
                                root.select_tts_model_path();
                            }
                        }
                    }

                    HorizontalLayout {
                        height: 28px;
                        spacing: 10px;
                        Text {
                            text: "输出路径";
                            width: 70px;
                            vertical-alignment: center;
                            font-size: 12px;
                            color: #1a2535;
                        }

                        LineEdit {
                            text <=> root.tts_output_path;
                        }

                        Button {
                            text: "选择";
                            width: 50px;
                            clicked => {
                                root.select_tts_output_path();
                            }
                        }
                    }

                    HorizontalLayout {
                        height: 28px;
                        spacing: 10px;
                        Text {
                            text: "参考音频";
                            width: 70px;
                            color: #1a2535;
                            vertical-alignment: center;
                            font-size: 12px;
                        }

                        LineEdit {
                            text <=> root.tts_ref_audio_path;
                        }

                        Button {
                            text: "选择";
                            width: 50px;
                            clicked => {
                                root.select_tts_ref_audio();
                            }
                        }
                    }

                    HorizontalLayout {
                        height: 28px;
                        spacing: 10px;
                        Text {
                            text: "参考文本";
                            width: 70px;
                            vertical-alignment: center;
                            font-size: 12px;
                            color: #1a2535;
                        }

                        LineEdit {
                            text <=> root.tts_ref_text;
                        }
                    }
                }
            }

            // 5. Demucs 人声分离卡片
            Rectangle {
                background: #ffffff;
                border-radius: 8px;
                border-width: 1px;
                border-color: #e0e0e0;
                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;
                    Text {
                        text: "🎵 Demucs 人声分离";
                        font-weight: 700;
                        color: #333;
                    }

                    HorizontalLayout {
                        height: 28px;
                        spacing: 10px;
                        Text {
                            text: "模型路径";
                            width: 70px;
                            vertical-alignment: center;
                            font-size: 12px;
                            color: #1a2535;
                        }

                        LineEdit {
                            text <=> root.demucs_model_path;
                        }

                        Button {
                            text: "选择";
                            width: 50px;
                            clicked => {
                                root.select_demucs_model_path();
                            }
                        }
                    }
                }
            }

            // 6. 通用设置卡片
            Rectangle {
                background: #ffffff;
                border-radius: 8px;
                border-width: 1px;
                border-color: #e0e0e0;
                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;
                    Text {
                        text: "⚙️  通用设置";
                        font-weight: 700;
                        color: #333;
                    }

                    Text {
                        text: "更多设置即将推出...";
                        font-size: 12px;
                        color: #999;
                    }
                }
            }
        }

        // --- 底部提示 ---
        Text {
            text: "💡 修改即时生效，但需点击保存按钮以持久化配置";
            font-size: 11px;
            color: #999;
            horizontal-alignment: center;
        }
    }
}
