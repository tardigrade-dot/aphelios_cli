import { Button, LineEdit, ScrollView } from "std-widgets.slint";

export component SettingsPage inherits Rectangle {
    in-out property <bool> dark_mode: false;
    background: dark_mode ? #1e1e2e : #f6f6f6;

    // 属性定义
    in-out property <string> ocr_model_path;
    in-out property <string> ocr_output_dir;

    // ASR 语音识别设置
    in-out property <string> asr_model_path;
    in-out property <string> asr_aligner_model_path;
    in-out property <string> asr_vad_model_path;

    // SRT 文本对齐设置
    in-out property <string> srt_model_path;
    in-out property <string> srt_min_segment_length: "80";
    in-out property <string> srt_max_segment_length: "120";

    // TTS 设置
    in-out property <string> tts_model_path;
    in-out property <string> tts_output_path;
    in-out property <string> tts_ref_audio_path;
    in-out property <string> tts_ref_text;

    // Demucs 人声分离设置
    in-out property <string> demucs_model_path;

    // 搜索设置
    in-out property <string> books_dir;

    // 保存状态
    in-out property <string> save_status_message: "";

    // Color palette
    in-out property <color> text-primary: dark_mode ? #e0e0e0 : #1a2535;
    in-out property <color> text-secondary: dark_mode ? #a0a0b0 : #666;
    in-out property <color> text-muted: dark_mode ? #7a7a8a : #999;
    in-out property <color> text-heading: dark_mode ? #e0e0e0 : #333;
    in-out property <color> label-color: dark_mode ? #c0c0d0 : #1a2535;
    in-out property <color> panel-bg: dark_mode ? #2b2b3d : #ffffff;
    in-out property <color> card-border: dark_mode ? #3a3a4f : #e0e0e0;

    callback save_settings();
    callback select_ocr_model_path();
    callback select_ocr_output_dir();
    callback select_asr_model_path();
    callback select_asr_aligner_model_path();
    callback select_asr_vad_model_path();
    callback select_srt_model_path();
    callback select_tts_model_path();
    callback select_tts_output_path();
    callback select_tts_ref_audio();
    callback select_demucs_model_path();
    callback select_books_dir();

    VerticalLayout {
        padding: 20px;
        spacing: 16px;
        alignment: stretch;

        // --- 头部工具栏 ---
        HorizontalLayout {
            height: 32px;
            alignment: space-between;

            Text {
                text: "应用偏好设置";
                font-size: 16px;
                font-weight: 700;
                color: text-primary;
                vertical-alignment: center;
            }

            HorizontalLayout {
                spacing: 10px;
                alignment: center;

                if save_status_message != "": Text {
                    text: save_status_message;
                    font-size: 12px;
                    color: #52c41a;
                    vertical-alignment: center;
                }

                Button {
                    text: "💾 保存设置";
                    width: 90px;
                    primary: true;
                    enabled: save_status_message == "";
                    clicked => {
                        root.save_settings();
                    }
                }
            }
        }

        // --- 设置滚动区 ---
        ScrollView {
            vertical-stretch: 1;
            horizontal-stretch: 0;
            width: 100%;
            height: 100%;

            VerticalLayout {
                spacing: 12px;

                // 1. OCR 卡片
            Rectangle {
                    background: panel-bg;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: card-border;
                    VerticalLayout {
                        accessible-role: AccessibleRole.none;
                        alignment: LayoutAlignment.stretch;
                        padding: 12px;
                        spacing: 8px;
                        Text {
                            text: "📝 OCR 识别设置";
                            font-weight: 700;
                            color: text-heading;
                        }

                    HorizontalLayout {
                            height: 28px;
                            spacing: 10px;
                            Text {
                                text: "模型路径";
                                width: 70px;
                                vertical-alignment: center;
                                font-size: 12px;
                                color: label-color;
                            }

                            LineEdit {
                                text <=> root.ocr_model_path;
                            }

                            Button {
                                text: "选择";
                                width: 50px;
                                clicked => {
                                    root.select_ocr_model_path();
                                }
                            }
                        }

                        HorizontalLayout {
                            height: 28px;
                            spacing: 10px;
                            Text {
                                text: "输出目录";
                                width: 70px;
                                vertical-alignment: center;
                                font-size: 12px;
                                color: label-color;
                            }

                            LineEdit {
                                text <=> root.ocr_output_dir;
                            }

                            Button {
                                text: "选择";
                                width: 50px;
                                clicked => {
                                    root.select_ocr_output_dir();
                                }
                            }
                        }
                    }
                }

                // 2. ASR 卡片
            Rectangle {
                    background: panel-bg;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: card-border;
                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;
                        Text {
                            text: "🎤 ASR 语音识别";
                            font-weight: 700;
                            color: text-heading;
                        }

                        HorizontalLayout {
                            height: 28px;
                            spacing: 10px;
                            Text {
                                text: "ASR模型";
                                width: 70px;
                                vertical-alignment: center;
                                font-size: 12px;
                                color: label-color;
                            }

                            LineEdit {
                                text <=> root.asr_model_path;
                            }

                            Button {
                                text: "选择";
                                width: 50px;
                                clicked => {
                                    root.select_asr_model_path();
                                }
                            }
                        }

                        HorizontalLayout {
                            height: 28px;
                            spacing: 10px;
                            Text {
                                text: "Aligner模型";
                                width: 70px;
                                vertical-alignment: center;
                                font-size: 12px;
                                color: label-color;
                            }

                            LineEdit {
                                text <=> root.asr_aligner_model_path;
                            }

                            Button {
                                text: "选择";
                                width: 50px;
                                clicked => {
                                    root.select_asr_aligner_model_path();
                                }
                            }
                        }

                        HorizontalLayout {
                            height: 28px;
                            spacing: 10px;
                            Text {
                                text: "VAD模型";
                                width: 70px;
                                vertical-alignment: center;
                                font-size: 12px;
                                color: label-color;
                            }

                            LineEdit {
                                text <=> root.asr_vad_model_path;
                            }

                            Button {
                                text: "选择";
                                width: 50px;
                                clicked => {
                                    root.select_asr_vad_model_path();
                                }
                            }
                        }
                    }
                }

                // 3. SRT 文本对齐卡片
            Rectangle {
                    background: panel-bg;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: card-border;
                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;
                        Text {
                            text: "📝 SRT 文本对齐";
                            font-weight: 700;
                            color: text-heading;
                        }

                        HorizontalLayout {
                            height: 28px;
                            spacing: 10px;
                            Text {
                                text: "模型路径";
                                width: 70px;
                                vertical-alignment: center;
                                font-size: 12px;
                                color: label-color;
                            }

                            LineEdit {
                                text <=> root.srt_model_path;
                            }

                            Button {
                                text: "选择";
                                width: 50px;
                                clicked => {
                                    root.select_srt_model_path();
                                }
                            }
                        }

                        HorizontalLayout {
                            height: 28px;
                            spacing: 10px;
                            Text {
                                text: "分段长度";
                                width: 70px;
                                vertical-alignment: center;
                                font-size: 12px;
                                color: label-color;
                            }

                            LineEdit {
                                text <=> root.srt_min_segment_length;
                                width: 60px;
                            }

                            Text {
                                text: "~";
                                vertical-alignment: center;
                                color: label-color;
                            }

                            LineEdit {
                                text <=> root.srt_max_segment_length;
                                width: 60px;
                            }

                            Text {
                                text: "字";
                                vertical-alignment: center;
                                color: label-color;
                            }
                        }
                    }
                }

                // 4. TTS 卡片
            Rectangle {
                    background: panel-bg;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: card-border;
                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;
                        Text {
                            text: "🔊 TTS 语音合成";
                            font-weight: 700;
                            color: text-heading;
                        }

                        HorizontalLayout {
                            height: 28px;
                            spacing: 10px;
                            Text {
                                text: "模型路径";
                                width: 70px;
                                vertical-alignment: center;
                                font-size: 12px;
                                color: label-color;
                            }

                            LineEdit {
                                text <=> root.tts_model_path;
                            }

                            Button {
                                text: "选择";
                                width: 50px;
                                clicked => {
                                    root.select_tts_model_path();
                                }
                            }
                        }

                        HorizontalLayout {
                            height: 28px;
                            spacing: 10px;
                            Text {
                                text: "输出路径";
                                width: 70px;
                                vertical-alignment: center;
                                font-size: 12px;
                                color: label-color;
                            }

                            LineEdit {
                                text <=> root.tts_output_path;
                            }

                            Button {
                                text: "选择";
                                width: 50px;
                                clicked => {
                                    root.select_tts_output_path();
                                }
                            }
                        }

                        HorizontalLayout {
                            height: 28px;
                            spacing: 10px;
                            Text {
                                text: "参考音频";
                                width: 70px;
                                color: label-color;
                                vertical-alignment: center;
                                font-size: 12px;
                            }

                            LineEdit {
                                text <=> root.tts_ref_audio_path;
                            }

                            Button {
                                text: "选择";
                                width: 50px;
                                clicked => {
                                    root.select_tts_ref_audio();
                                }
                            }
                        }

                        HorizontalLayout {
                            height: 28px;
                            spacing: 10px;
                            Text {
                                text: "参考文本";
                                width: 70px;
                                vertical-alignment: center;
                                font-size: 12px;
                                color: label-color;
                            }

                            LineEdit {
                                text <=> root.tts_ref_text;
                            }
                        }
                    }
                }

                // 5. Demucs 人声分离卡片
            Rectangle {
                    background: panel-bg;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: card-border;
                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;
                        Text {
                            text: "🎵 Demucs 人声分离";
                            font-weight: 700;
                            color: text-heading;
                        }

                        HorizontalLayout {
                            height: 28px;
                            spacing: 10px;
                            Text {
                                text: "模型路径";
                                width: 70px;
                                vertical-alignment: center;
                                font-size: 12px;
                                color: label-color;
                            }

                            LineEdit {
                                text <=> root.demucs_model_path;
                            }

                            Button {
                                text: "选择";
                                width: 50px;
                                clicked => {
                                    root.select_demucs_model_path();
                                }
                            }
                        }
                    }
                }

                // 6. 搜索设置卡片
            Rectangle {
                    background: panel-bg;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: card-border;
                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;
                        Text {
                            text: "🔍 搜索设置";
                            font-weight: 700;
                            color: text-heading;
                        }

                        HorizontalLayout {
                            height: 28px;
                            spacing: 10px;
                            Text {
                                text: "书籍目录";
                                width: 70px;
                                vertical-alignment: center;
                                font-size: 12px;
                                color: label-color;
                            }

                            LineEdit {
                                text <=> root.books_dir;
                            }

                            Button {
                                text: "选择";
                                width: 50px;
                                clicked => {
                                    root.select_books_dir();
                                }
                            }
                        }
                    }
                }

                // 7. 通用设置卡片
            Rectangle {
                    background: panel-bg;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: card-border;
                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;
                        Text {
                            text: "⚙️  通用设置";
                            font-weight: 700;
                            color: text-heading;
                        }

                        Text {
                            text: "更多设置即将推出...";
                            font-size: 12px;
                            color: text-muted;
                        }
                    }
                }
            }
        }

        // --- 底部提示 ---
        Text {
            text: "💡 修改即时生效，但需点击保存按钮以持久化配置";
            font-size: 11px;
            color: text-muted;
            horizontal-alignment: center;
        }
    }
}
