import {
    Button,
    ComboBox,
    LineEdit,
    ListView,
} from "std-widgets.slint";

export struct BookItem {
    id: string,
    title: string,
    author: string,
    file_path: string,
    file_type: string,
    file_size: string,
}

export component BookSearchPage inherits Rectangle {
    background: #eef1f6;

    in-out property <string> search_query: "";
    in-out property <string> books_dir: "/Volumes/sw/books";
    in-out property <string> status_message: "就绪";
    in-out property <int> book_count: 0;
    in-out property <bool> is_indexing: false;
    in-out property <int> selected_index: -1;
    in-out property <string> selected_file_path: "";
    in-out property <[BookItem]> search_results: [];
    in-out property <string> search_mode: "keyword";
    in-out property <string> index_status_text: "";
    in-out property <bool> has_index: false;
    in-out property <bool> has_semantic_index: false;

    // Context menu state (global)
    in-out property <bool> show_context_menu: false;
    in-out property <length> context_menu_x: 0px;
    in-out property <length> context_menu_y: 0px;
    in-out property <string> context_menu_file_path: "";

    callback build_index();
    callback search_books(string);
    callback open_book(string);
    callback reveal_in_finder(string);

    VerticalLayout {
        padding: 16px;
        spacing: 14px;
        alignment: stretch;

        // ── 头部
        HorizontalLayout {
            height: 28px;
            alignment: center;

            Text {
                text: "书籍搜索";
                font-size: 14px;
                font-weight: 700;
                color: #1a2535;
                vertical-alignment: center;
            }
            
            // 状态胶囊
            Rectangle {
                width: 86px;
                height: 20px;
                border-radius: 10px;
                background: is_indexing ? #1565c0 : #d0d8e4;
                animate background { duration: 250ms; }
                Text {
                    text: is_indexing ? "索引构建中" : status_message;
                    font-size: 11px;
                    font-weight: 600;
                    color: is_indexing ? #ffffff : #4e5f75;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #d0d8e4;
        }

        // ── 搜索与目录
        VerticalLayout {
            spacing: 8px;

            Text {
                text: "🔍  搜索";
                font-size: 11px;
                font-weight: 600;
                color: #6b7a8d;
            }

            HorizontalLayout {
                height: 26px;
                spacing: 10px;
                Text {
                    text: "模式";
                    width: 44px;
                    font-size: 12px;
                    color: #1a2535;
                    vertical-alignment: center;
                }

                ComboBox {
                    width: 90px;
                    current-value: search_mode;
                    model: ["keyword", "semantic", "hybrid"];
                    selected(v) => {
                        search_mode = v;
                    }
                }

                LineEdit {
                    text <=> search_query;
                    font-size: 12px;
                    placeholder-text: "输入书名或作者名…";
                    accepted => {
                        search_books(root.search_query);
                    }
                }

                Button {
                    text: "搜索";
                    width: 56px;
                    clicked => {
                        search_books(root.search_query);
                    }
                }
            }

            HorizontalLayout {
                height: 26px;
                spacing: 10px;
                Text {
                    text: "书籍目录";
                    width: 44px;
                    font-size: 12px;
                    color: #1a2535;
                    vertical-alignment: center;
                }

                LineEdit {
                    text <=> books_dir;
                    font-size: 12px;
                    placeholder-text: "书籍目录路径";
                }

                Button {
                    text: "重建索引";
                    width: 70px;
                    enabled: !is_indexing;
                    clicked => {
                        build_index();
                    }
                }
            }

            // 索引状态显示
            if has_index: HorizontalLayout {
                height: 20px;
                spacing: 10px;
                Text {
                    text: "📊  索引状态";
                    width: 70px;
                    font-size: 11px;
                    font-weight: 600;
                    color: #1a2535;
                    vertical-alignment: center;
                }

                Text {
                    text: index_status_text;
                    font-size: 10px;
                    color: #6b7a8d;
                    vertical-alignment: center;
                }
            }

            // 状态行
            HorizontalLayout {
                spacing: 12px;
                height: 18px;
                Text {
                    text: "共 " + book_count + " 本";
                    font-size: 11px;
                    color: #8a9bb0;
                    vertical-alignment: center;
                }

                Text {
                    text: status_message;
                    font-size: 11px;
                    color: #b0bec5;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #d0d8e4;
        }

        // ── 搜索结果
        Text {
            text: "📋  搜索结果";
            font-size: 11px;
            font-weight: 600;
            color: #6b7a8d;
        }

        Rectangle {
            vertical-stretch: 1;
            min-height: 200px;

            ListView {
                width: parent.width;
                height: parent.height;
                for item in search_results: Rectangle {
                    height: 80px;
                    border-width: 0px;

                    VerticalLayout {
                        padding-top: 8px;
                        padding-bottom: 8px;
                        spacing: 3px;

                        HorizontalLayout {
                            alignment: space-between;
                            Text {
                                text: item.title;
                                font-size: 13px;
                                font-weight: 600;
                                color: #1a2535;
                            }

                            HorizontalLayout {
                                spacing: 10px;
                                alignment: end;
                                Text {
                                    text: item.file_type;
                                    font-size: 10px;
                                    color: #8a9bb0;
                                    vertical-alignment: center;
                                }

                                Button {
                                    text: "打开";
                                    height: 22px;
                                    width: 46px;
                                    clicked => {
                                        open_book(item.file_path);
                                    }
                                }
                            }
                        }

                        if item.author != "": Text {
                            text: item.author;
                            font-size: 11px;
                            color: #6b7a8d;
                        }

                        Text {
                            text: item.file_path;
                            font-size: 10px;
                            color: #b0bec5;
                            wrap: word-wrap;
                        }

                        Text {
                            text: item.file_size;
                            font-size: 10px;
                            color: #c8d0db;
                        }
                    }

                    // Handle right-click to show context menu
                    TouchArea {
                        width: parent.width;
                        height: parent.height;

                        pointer-event(event) => {
                            if event.button == PointerEventButton.right {
                                root.show_context_menu = true;
                                root.context_menu_x = 320px;
                                root.context_menu_y = 260px;
                                root.context_menu_file_path = item.file_path;
                            }
                        }
                    }

                    // 每行底部细线
                    Rectangle {
                        y: parent.height - 1px;
                        height: 1px;
                        background: #d0d8e4;
                    }
                }
            }
        }
    }

    // Global context menu overlay (renders on top of everything)
    Rectangle {
        visible: root.show_context_menu;
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        z: 1000;

        // Context menu popup (must be before overlay TouchArea to handle clicks)
        Rectangle {
            x: root.context_menu_x;
            y: root.context_menu_y;
            width: 160px;
            height: 68px;
            background: #ffffff;
            border-radius: 6px;
            border-width: 1px;
            border-color: #d0d8e4;
            z: 1002;

            VerticalLayout {
                padding: 4px;
                spacing: 2px;
                alignment: stretch;

                // Open
                Rectangle {
                    height: 28px;
                    border-radius: 4px;
                    background: #e8edf3;

                    TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => {
                            open_book(root.context_menu_file_path);
                            root.show_context_menu = false;
                        }

                        Text {
                            text: "打开";
                            font-size: 12px;
                            color: #1a2535;
                            vertical-alignment: center;
                        }
                    }
                }

                // Reveal in Finder/Explorer
                Rectangle {
                    height: 28px;
                    border-radius: 4px;
                    background: #e8edf3;

                    TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => {
                            reveal_in_finder(root.context_menu_file_path);
                            root.show_context_menu = false;
                        }

                        Text {
                            text: "打开文件位置";
                            font-size: 12px;
                            color: #1a2535;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // Semi-transparent background overlay (after context menu so it's behind)
        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: #00000020;
            z: 1001;

            // Close menu when clicking outside
            TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => {
                    root.show_context_menu = false;
                }
            }
        }
    }
}
