import { Button, VerticalBox, HorizontalBox, GroupBox, LineEdit, StandardListView } from "std-widgets.slint";
import "./pingfang-sc-regular.ttf";

export component AsrWindow inherits Window {
    width: 900px;
    height: 700px;
    title: "Parakeet ASR";

    default-font-family: "PingFang SC";
    default-font-size: 14px;

    in-out property <string> audio_file_path;
    in-out property <string> output_path;
    in-out property <string> status_message;
    in-out property <bool> is_running;
    in-out property <[string]> log_messages;
    in-out property <string> transcription_result;

    callback select_audio_file();
    callback select_output_path();
    callback start_asr();
    callback go_back();

    VerticalBox {
        alignment: start;

        HorizontalBox {
            alignment: center;
            spacing: 10px;
            
            Button {
                text: "← 返回主菜单";
                min-width: 100px;
                clicked => {
                    root.go_back();
                }
            }
            
            Text {
                text: "Parakeet ASR 语音识别";
                font-size: 20px;
                font-weight: 700;
                color: #333333;
            }
        }

        GroupBox {
            title: "输入文件";
            HorizontalBox {
                LineEdit {
                    text <=> audio_file_path;
                    placeholder-text: "选择音频文件 (WAV, MP3, FLAC 等)";
                    enabled: !is_running;
                }
                Button {
                    text: "选择文件";
                    clicked => {
                        root.select_audio_file();
                    }
                    enabled: !is_running;
                }
            }
        }

        GroupBox {
            title: "输出路径";
            HorizontalBox {
                LineEdit {
                    text <=> output_path;
                    placeholder-text: "选择输出文件路径";
                    enabled: !is_running;
                }
                Button {
                    text: "选择路径";
                    clicked => {
                        root.select_output_path();
                    }
                    enabled: !is_running;
                }
            }
        }

        HorizontalBox {
            alignment: center;
            spacing: 20px;
            
            Button {
                text: "开始识别";
                clicked => {
                    root.start_asr();
                }
                enabled: audio_file_path != "" && !is_running;
            }
        }

        GroupBox {
            title: "状态";
            VerticalBox {
                Text {
                    text: status_message;
                    font-weight: 700;
                    color: is_running ? #0066cc : #333333;
                }
            }
        }

        GroupBox {
            title: "识别结果";
            min-height: 150px;
            VerticalBox {
                LineEdit {
                    text <=> transcription_result;
                    placeholder-text: "识别结果将显示在这里...";
                    enabled: false;
                    height: 100px;
                }
            }
        }

        GroupBox {
            title: "日志";
            min-height: 150px;
            VerticalBox {
                StandardListView {
                    width: 100%;
                    height: 100%;
                    for msg in log_messages: Text {
                        text: msg;
                    }
                }
            }
        }
    }
}
