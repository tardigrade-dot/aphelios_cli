import {
    Button,
    ComboBox,
    LineEdit,
    ProgressIndicator,
    ScrollView,
} from "std-widgets.slint";

export component AsrPage inherits Rectangle {
    in-out property <bool> dark_mode: false;
    background: dark_mode ? #1e1e2e : #eef1f6;

    in-out property <string> asr_model_path;
    in-out property <string> aligner_model_path;
    in-out property <string> vad_model_path;
    in-out property <string> audio_file_path;
    in-out property <string> output_path;
    in-out property <string> language: "English";
    in-out property <string> status_message: "Ready";
    in-out property <bool> is_running: false;
    in-out property <float> progress: 0.0;
    in-out property <string> stage_name: "VAD";
    in-out property <int> stage_index: 1;
    in-out property <int> total_stages: 3;
    in-out property <[string]> log_messages: ["Session started"];
    in-out property <string> transcription_result;
    in-out property <length> log_viewport_y: 0;

    // Color palette
    in-out property <color> text-primary: dark_mode ? #e0e0e0 : #1a2535;
    in-out property <color> text-secondary: dark_mode ? #a0a0b0 : #666;
    in-out property <color> text-muted: dark_mode ? #7a7a8a : #999;
    in-out property <color> label-color: dark_mode ? #c0c0d0 : #333;
    in-out property <color> panel-bg: dark_mode ? #2b2b3d : #ffffff;
    in-out property <color> card-border: dark_mode ? #3a3a4f : #e0e0e0;
    in-out property <color> accent-color: dark_mode ? #4fc3f7 : #1565c0;

    callback scroll_to_bottom();
    scroll_to_bottom => {
        log_viewport_y = -100000px;
    }

    callback select_audio_file();
    callback select_output_path();
    callback start_asr();

    VerticalLayout {
        padding: 20px;
        spacing: 15px;
        alignment: start;

        // --- 标题栏 ---
        HorizontalLayout {
            height: 32px;
            alignment: center;

            Text {
                text: "Parakeet ASR 语音识别";
                font-size: 16px;
                font-weight: 700;
                color: text-primary;
                vertical-alignment: center;
            }
            // 状态指示灯
            HorizontalLayout {
                spacing: 8px;
                Rectangle {
                    width: 10px;
                    height: 10px;
                    border-radius: 5px;
                    background: is_running ? #00ff00 : #cccccc;
                    y: (parent.height - self.height) / 2;
                }

                Text {
                    text: status_message;
                    font-size: 12px;
                    color: text-secondary;
                    vertical-alignment: center;
                }
            }
        }

        // --- 核心配置卡片 (输入输出) ---
        Rectangle {
            background: panel-bg;
            border-radius: 8px;
            border-width: 1px;
            border-color: card-border;
            vertical-stretch: 0;

            VerticalLayout {
                padding: 15px;
                spacing: 12px;

                // ASR 模型路径行
                HorizontalLayout {
                    height: 30px;
                    spacing: 10px;
                    Text {
                        text: "ASR模型";
                        width: 60px;
                        vertical-alignment: center;
                        font-size: 12px;
                        color: label-color;
                    }

                    LineEdit {
                        text <=> asr_model_path;
                        placeholder-text: "ASR 模型路径";
                        enabled: !is_running;
                    }
                }

                // Aligner 模型路径行
                HorizontalLayout {
                    height: 30px;
                    spacing: 10px;
                    Text {
                        text: "Aligner";
                        width: 60px;
                        vertical-alignment: center;
                        font-size: 12px;
                        color: label-color;
                    }

                    LineEdit {
                        text <=> aligner_model_path;
                        placeholder-text: "Aligner 模型路径";
                        enabled: !is_running;
                    }
                }

                // VAD 模型路径行
                HorizontalLayout {
                    height: 30px;
                    spacing: 10px;
                    Text {
                        text: "VAD模型";
                        width: 60px;
                        vertical-alignment: center;
                        font-size: 12px;
                        color: label-color;
                    }

                    LineEdit {
                        text <=> vad_model_path;
                        placeholder-text: "VAD 模型路径";
                        enabled: !is_running;
                    }
                }

                // 语言选择行
                HorizontalLayout {
                    height: 30px;
                    spacing: 10px;
                    Text {
                        text: "语言";
                        width: 60px;
                        vertical-alignment: center;
                        font-size: 12px;
                        color: label-color;
                    }

                    ComboBox {
                        current-value <=> root.language;
                        enabled: !is_running;
                        model: ["English", "Chinese", "Japanese", "Korean"];
                        width: 120px;
                    }
                }

                // 输入音频行
                HorizontalLayout {
                    height: 30px;
                    spacing: 10px;
                    Text {
                        text: "输入音频";
                        width: 60px;
                        vertical-alignment: center;
                        font-size: 12px;
                        color: label-color;
                    }

                    LineEdit {
                        text <=> audio_file_path;
                        placeholder-text: "请选择待识别的音频文件...";
                        enabled: !is_running;
                    }

                    Button {
                        text: "选择";
                        width: 60px;
                        clicked => {
                            root.select_audio_file();
                        }
                        enabled: !is_running;
                    }
                }

                // 输出路径行
                HorizontalLayout {
                    height: 30px;
                    spacing: 10px;
                    Text {
                        text: "SRT路径";
                        width: 60px;
                        vertical-alignment: center;
                        font-size: 12px;
                        color: label-color;
                    }

                    LineEdit {
                        text <=> output_path;
                        placeholder-text: "字幕文件保存位置 (默认同路径同名的.srt)";
                        enabled: !is_running;
                    }

                    Button {
                        text: "选择";
                        width: 60px;
                        clicked => {
                            root.select_output_path();
                        }
                        enabled: !is_running;
                    }
                }
            }
        }

        // --- 操作中心 ---
        HorizontalLayout {
            alignment: center;
            height: 40px;
            Button {
                text: is_running ? "正在识别..." : "▶  开始语音识别";
                primary: true;
                width: 200px;
                height: 36px;
                enabled: audio_file_path != "" && !is_running;
                clicked => {
                    root.start_asr();
                }
            }
        }

        // --- 进度（运行时） ---
        if is_running: VerticalLayout {
            spacing: 4px;

            // 阶段提示
            Text {
                text: "当前阶段 " + stage_name + " (" + stage_index + "/" + total_stages + ") 正在执行";
                font-size: 11px;
                color: accent-color;
                font-weight: 600;
            }

            HorizontalLayout {
                height: 16px;
                spacing: 10px;
                ProgressIndicator {
                    progress: progress;
                    height: 4px;
                    horizontal-stretch: 1;
                }

                // 只在ASR阶段显示百分比
                if stage_name == "ASR": Text {
                    text: Math.round(progress * 100) + "%";
                    font-size: 11px;
                    font-weight: 600;
                    color: accent-color;
                    width: 32px;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
            }
        }


        // --- 日志终端 ---
        VerticalLayout {
            spacing: 5px;
            vertical-stretch: 2;
            Text {
                text: "系统日志";
                font-size: 11px;
                color: text-muted;
            }

            Rectangle {
                background: #1e1e1e;
                border-radius: 6px;
                min-height: 120px;
                clip: true;

                ScrollView {
                    viewport-y <=> log_viewport_y;
                    VerticalLayout {
                        alignment: start;
                        for msg in log_messages: Text {
                            text: "> " + msg;
                            color: #a6e22e;
                            font-family: "PingFang SC";
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                    }
                }
            }
        }
    }
}
