import {
    Button,
    LineEdit,
    ProgressIndicator,
    ScrollView,
} from "std-widgets.slint";

export component OcrPage inherits Rectangle {
    in-out property <bool> dark_mode: false;
    background: dark_mode ? #1e1e2e : #f6f6f6;

    in-out property <string> model_path: "/Volumes/sw/pretrained_models/Dolphin-v1.5";
    in-out property <string> input_file_path;
    in-out property <string> output_dir_path: "/Users/larry/Documents/resources";
    in-out property <[string]> log_messages: ["Ready", "Waiting for input..."];
    in-out property <bool> is_running: false;
    in-out property <string> status_message: "";
    in-out property <float> progress: 0.0;
    in-out property <length> log_viewport_y: 0;

    // Color palette
    in-out property <color> text-primary: dark_mode ? #e0e0e0 : #1a2535;
    in-out property <color> text-secondary: dark_mode ? #a0a0b0 : #666;
    in-out property <color> text-muted: dark_mode ? #7a7a8a : #999;
    in-out property <color> panel-bg: dark_mode ? #2b2b3d : #ffffff;
    in-out property <color> card-border: dark_mode ? #3a3a4f : #e0e0e0;
    in-out property <color> accent-color: dark_mode ? #4fc3f7 : #1565c0;

    callback scroll_to_bottom();
    scroll_to_bottom => {
        log_viewport_y = -100000px;
    }

    callback select_input_file();
    callback select_output_dir();
    callback select_model_path();
    callback start_ocr();
    callback stop_ocr();

    VerticalLayout {
        padding: 16px;
        spacing: 12px;
        alignment: start;

        // --- 顶部状态与标题 ---
        HorizontalLayout {
            alignment: center;

            Text {
                text: "Dolphin OCR 文字识别";
                font-size: 14px;
                font-weight: 600;
                color: text-primary;
                vertical-alignment: center;
            }
        }

        // --- 主配置面板 ---
        Rectangle {
            background: panel-bg;
            border-radius: 8px;
            border-width: 1px;
            border-color: card-border;

            VerticalLayout {
                padding: 12px;
                spacing: 10px;

                // 模型路径行
                HorizontalLayout {
                    spacing: 8px;
                    height: 28px;
                    Text {
                        text: "模型路径";
                        vertical-alignment: center;
                        width: 60px;
                        font-size: 12px;
                        color: text-primary;
                    }

                    LineEdit {
                        text <=> model_path;
                    }

                    Button {
                        text: "选择";
                        width: 50px;
                        clicked => {
                            select_model_path();
                        }
                    }
                }

                // 输入/输出并排
                HorizontalLayout {
                    spacing: 16px;
                    height: 28px;
                    // 输入
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: "输入文件";
                            vertical-alignment: center;
                            width: 60px;
                            font-size: 12px;
                            color: text-secondary;
                        }

                        LineEdit {
                            text <=> input_file_path;
                            placeholder-text: "图片/PDF";
                        }

                        Button {
                            text: "选择";
                            width: 50px;
                            clicked => {
                                select_input_file();
                            }
                        }
                    }
                    // 输出
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: "输出目录";
                            vertical-alignment: center;
                            width: 60px;
                            font-size: 12px;
                            color: text-secondary;
                        }

                        LineEdit {
                            text <=> output_dir_path;
                        }

                        Button {
                            text: "选择";
                            width: 50px;
                            clicked => {
                                select_output_dir();
                            }
                        }
                    }
                }
            }
        }

        // --- 核心操作区 ---
        HorizontalLayout {
            alignment: center;
            spacing: 12px;
            padding: 8px;
            Button {
                text: "开始识别";
                primary: true;
                width: 100px;
                height: 30px;
                clicked => {
                    start_ocr();
                }
            }

            Button {
                text: "停止";
                width: 80px;
                height: 30px;
                clicked => {
                    stop_ocr();
                }
            }
        }

        // --- 进度（运行时） ---
        if is_running: VerticalLayout {
            spacing: 4px;

            Text {
                text: Math.round(progress * 100) + "%";
                font-size: 11px;
                color: accent-color;
                font-weight: 600;
            }

            HorizontalLayout {
                height: 16px;
                spacing: 10px;
                ProgressIndicator {
                    progress: progress;
                    height: 4px;
                    horizontal-stretch: 1;
                }
            }
        }

        Text {
            text: " 运行日志";
            font-size: 11px;
            color: text-muted;
        }

        Rectangle {
            background: #1e1e1e;
            border-radius: 6px;
            vertical-stretch: 1;
            min-height: 360px;
            clip: true;

            ScrollView {
                viewport-y <=> log_viewport_y;
                VerticalLayout {
                    padding: 8px;
                    spacing: 4px;
                    alignment: start;
                    for msg in log_messages: Text {
                        text: msg;
                        color: #bff50e;
                        font-family: "PingFang SC";
                        font-size: 11px;
                        wrap: word-wrap;
                    }
                }
            }
        }
    }
}
