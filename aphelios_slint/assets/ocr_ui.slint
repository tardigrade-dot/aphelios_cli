import { Button, VerticalBox, HorizontalBox, GroupBox, LineEdit, ListView } from "std-widgets.slint";
import "./pingfang-sc-regular.ttf";

export component OcrWindow inherits Window {
    width: 900px;
    height: 700px;
    title: "Dolphin OCR";

    default-font-family: "PingFang SC";
    default-font-size: 14px;

    in-out property <string> input_file_path;
    in-out property <string> output_dir_path;
    in-out property <string> model_path;
    in-out property <string> status_message;
    in-out property <bool> is_running;
    in-out property <[string]> log_messages;

    callback select_input_file();
    callback select_output_dir();
    callback start_ocr();
    callback stop_ocr();

    VerticalBox {
        alignment: start;

        GroupBox {
            title: "模型设置";
            HorizontalBox {
                Text {
                    text: "模型路径:";
                    vertical-alignment: center;
                }
                LineEdit {
                    text <=> model_path;
                    placeholder-text: "请输入 Dolphin 模型路径";
                    enabled: !is_running;
                }
            }
        }

        GroupBox {
            title: "输入文件";
            HorizontalBox {
                LineEdit {
                    text <=> input_file_path;
                    placeholder-text: "选择图片或 PDF 文件";
                    enabled: !is_running;
                }
                Button {
                    text: "选择文件";
                    clicked => {
                        root.select_input_file();
                    }
                    enabled: !is_running;
                }
            }
        }

        GroupBox {
            title: "输出目录";
            HorizontalBox {
                LineEdit {
                    text <=> output_dir_path;
                    placeholder-text: "选择输出目录";
                    enabled: !is_running;
                }
                Button {
                    text: "选择目录";
                    clicked => {
                        root.select_output_dir();
                    }
                    enabled: !is_running;
                }
            }
        }

        HorizontalBox {
            alignment: center;
            Button {
                text: "开始 OCR";
                clicked => {
                    root.start_ocr();
                }
                enabled: input_file_path != "" && output_dir_path != "" && !is_running;
            }
            Button {
                text: "停止";
                clicked => {
                    root.stop_ocr();
                }
                enabled: is_running;
            }
        }

        GroupBox {
            title: "状态";
            VerticalBox {
                Text {
                    text: status_message;
                    font-weight: 700;
                    color: is_running ? #0066cc : #333333;
                }
            }
        }

        GroupBox {
            title: "日志";
            min-height: 200px;
            VerticalBox {
                ListView {
                    width: 100%;
                    height: 100%;
                    for msg in log_messages: Text {
                        text: msg;
                    }
                }
            }
        }
    }
}
