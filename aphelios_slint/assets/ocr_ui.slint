import { Button, VerticalBox, HorizontalBox, GroupBox, LineEdit, StandardListView } from "std-widgets.slint";
import "./pingfang-sc-regular.ttf";

export component OcrWindow inherits Window {
    width: 800px;
    height: 600px;
    title: "Dolphin OCR";

    default-font-family: "PingFang SC";
    default-font-size: 13px;

    in-out property <string> input_file_path;
    in-out property <string> output_dir_path;
    in-out property <string> model_path;
    in-out property <string> status_message;
    in-out property <bool> is_running;
    in-out property <[string]> log_messages;

    callback select_input_file();
    callback select_output_dir();
    callback start_ocr();
    callback stop_ocr();
    callback go_back();

    background: #f5f5f5;

    VerticalBox {
        spacing: 8px;
        padding: 10px;

        // 标题栏
        HorizontalBox {
            alignment: center;
            spacing: 10px;
            
            Button {
                text: "← 返回";
                min-width: 70px;
                min-height: 28px;
                clicked => { root.go_back(); }
            }
            
            Text {
                text: "Dolphin OCR 文字识别";
                font-size: 16px;
                font-weight: 700;
                color: #1a1a1a;
            }
        }

        // 模型路径
        GroupBox {
            title: "模型路径";
            HorizontalBox {
                LineEdit {
                    text <=> model_path;
                    placeholder-text: "Dolphin 模型路径";
                    enabled: !is_running;
                    min-height: 28px;
                }
                Button {
                    text: "选择";
                    min-width: 50px;
                    min-height: 28px;
                    clicked => { /* 可选择模型 */ }
                    enabled: !is_running;
                }
            }
        }

        // 输入和输出 - 单行
        HorizontalBox {
            spacing: 8px;
            
            GroupBox {
                title: "输入文件";
                HorizontalBox {
                    LineEdit {
                        text <=> input_file_path;
                        placeholder-text: "选择图片或 PDF";
                        enabled: !is_running;
                        min-height: 28px;
                    }
                    Button {
                        text: "选择";
                        min-width: 50px;
                        min-height: 28px;
                        clicked => { root.select_input_file(); }
                        enabled: !is_running;
                    }
                }
            }
            
            GroupBox {
                title: "输出目录";
                HorizontalBox {
                    LineEdit {
                        text <=> output_dir_path;
                        placeholder-text: "输出目录";
                        enabled: !is_running;
                        min-height: 28px;
                    }
                    Button {
                        text: "选择";
                        min-width: 50px;
                        min-height: 28px;
                        clicked => { root.select_output_dir(); }
                        enabled: !is_running;
                    }
                }
            }
        }

        // 操作按钮
        HorizontalBox {
            alignment: center;
            spacing: 15px;
            
            Button {
                text: "▶ 开始 OCR";
                min-width: 100px;
                min-height: 32px;
                clicked => { root.start_ocr(); }
                enabled: input_file_path != "" && output_dir_path != "" && !is_running;
            }
            
            Button {
                text: "⏹ 停止";
                min-width: 70px;
                min-height: 32px;
                clicked => { root.stop_ocr(); }
                enabled: is_running;
            }
            
            Text {
                text: status_message;
                font-weight: 600;
                color: is_running ? #0066cc : #666666;
            }
        }

        // 日志
        GroupBox {
            title: "日志";
            VerticalBox {
                StandardListView {
                    width: 100%;
                    height: 100%;
                    for msg in log_messages: Text {
                        text: msg;
                        color: #333333;
                    }
                }
            }
        }
    }
}
