import {
    Button,
    LineEdit,
    ScrollView,
    ProgressIndicator,
} from "std-widgets.slint";

export component DemucsPage inherits Rectangle {
    in-out property <bool> dark_mode: false;
    background: dark_mode ? #1e1e2e : #eef1f6;

    in-out property <string> audio_file_path;
    in-out property <string> model_path;
    in-out property <string> output_dir;
    in-out property <string> separation_mode: "vocals_instrumental";
    in-out property <string> status_message: "就绪";
    in-out property <bool> is_running: false;
    in-out property <float> progress: 0.0;
    in-out property <[string]> log_messages: ["Session Initialized"];
    in-out property <length> log_viewport_y: 0;

    // Color palette
    in-out property <color> text-primary: dark_mode ? #e0e0e0 : #1a2535;
    in-out property <color> text-secondary: dark_mode ? #a0a0b0 : #6b7a8d;
    in-out property <color> text-muted: dark_mode ? #7a7a8a : #8a9bb0;
    in-out property <color> label-color: dark_mode ? #c0c0d0 : #1a2535;
    in-out property <color> panel-bg: dark_mode ? #2b2b3d : #ffffff;
    in-out property <color> separator-color: dark_mode ? #3a3a4f : #d0d8e4;
    in-out property <color> accent-color: dark_mode ? #4fc3f7 : #1565c0;

    callback scroll_to_bottom();
    scroll_to_bottom => {
        log_viewport_y = -100000px;
    }

    callback select_audio_file();
    callback select_model_path();
    callback select_output_dir();
    callback toggle_separation_mode();
    callback start_separation();

    VerticalLayout {
        padding: 16px;
        spacing: 14px;
        alignment: start;

        // ── 头部
        HorizontalLayout {
            height: 28px;
            alignment: center;

            Text {
                text: "🎵 Demucs 人声分离中心";
                font-size: 14px;
                font-weight: 700;
                color: text-primary;
                vertical-alignment: center;
            }

            Rectangle {
                width: 86px;
                height: 20px;
                border-radius: 10px;
                background: is_running ? #1565c0 : separator-color;
                animate background { duration: 250ms; }
                Text {
                    text: status_message;
                    font-size: 11px;
                    font-weight: 600;
                    color: is_running ? #ffffff : #4e5f75;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            height: 1px;
            background: separator-color;
        }

        // ── 音频文件选择
        VerticalLayout {
            spacing: 6px;

            Text {
                text: "🎼 音频文件";
                font-size: 11px;
                font-weight: 600;
                color: text-secondary;
            }

            HorizontalLayout {
                height: 32px;
                spacing: 10px;

                LineEdit {
                    text <=> audio_file_path;
                    placeholder-text: "请选择要分离的音频文件 (.wav, .mp3, .flac, .ogg, .m4a)";
                    enabled: !is_running;
                }

                Button {
                    text: "选择文件";
                    width: 80px;
                    clicked => {
                        root.select_audio_file();
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: separator-color;
        }

        // ── 路径配置
        VerticalLayout {
            spacing: 8px;

            Text {
                text: "📂  路径配置";
                font-size: 11px;
                font-weight: 600;
                color: text-secondary;
            }

            HorizontalLayout {
                height: 26px;
                spacing: 10px;
                Text {
                    text: "模型路径";
                    width: 52px;
                    font-size: 12px;
                    color: label-color;
                    vertical-alignment: center;
                }

                LineEdit {
                    text <=> model_path;
                    font-size: 12px;
                    placeholder-text: "Demucs 模型文件夹路径";
                    enabled: !is_running;
                }

                Button {
                    text: "选择";
                    width: 46px;
                    clicked => {
                        root.select_model_path();
                    }
                }
            }

            HorizontalLayout {
                height: 26px;
                spacing: 10px;
                Text {
                    text: "输出目录";
                    width: 52px;
                    font-size: 12px;
                    color: label-color;
                    vertical-alignment: center;
                }

                LineEdit {
                    text <=> output_dir;
                    font-size: 12px;
                    placeholder-text: "留空则输出至输入音频同路径";
                    enabled: !is_running;
                }

                Button {
                    text: "选择";
                    width: 46px;
                    enabled: !is_running;
                    clicked => {
                        root.select_output_dir();
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: separator-color;
        }

        // ── 分离模式选择
        VerticalLayout {
            spacing: 8px;

            Text {
                text: "🔧  分离模式";
                font-size: 11px;
                font-weight: 600;
                color: text-secondary;
            }

            HorizontalLayout {
                spacing: 12px;
                alignment: center;

                Button {
                    text: separation_mode == "vocals_instrumental" ? "人声/伴奏" : "四轨分离";
                    width: 100px;
                    height: 26px;
                    enabled: !is_running;
                    clicked => {
                        root.toggle_separation_mode();
                    }
                }
            }

            Text {
                text: separation_mode == "vocals_instrumental" ? "输出：vocals_only.wav (人声) + instrumental_only.wav (伴奏)" : "输出：vocals.wav + drums.wav + bass.wav + other.wav";
                font-size: 10px;
                color: text-muted;
            }
        }

        Rectangle {
            height: 1px;
            background: separator-color;
        }

        // ── 进度（运行时）
        if is_running: VerticalLayout {
            spacing: 6px;

            Text {
                text: "分离进度";
                font-size: 11px;
                font-weight: 600;
                color: text-secondary;
            }

            HorizontalLayout {
                height: 16px;
                spacing: 10px;
                ProgressIndicator {
                    progress: progress;
                    height: 6px;
                    horizontal-stretch: 1;
                }

                Text {
                    text: Math.round(progress * 100) + "%";
                    font-size: 11px;
                    font-weight: 600;
                    color: accent-color;
                    width: 42px;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
            }
        }

        // ── 操作按钮
        HorizontalLayout {
            alignment: center;
            spacing: 12px;
            height: 34px;

            Button {
                text: is_running ? "分离中…" : "▶  开始分离";
                primary: true;
                width: 136px;
                height: 32px;
                enabled: audio_file_path != "" && model_path != "" && !is_running;
                clicked => {
                    root.start_separation();
                }
            }
        }

        // ── 系统日志
        VerticalLayout {
            vertical-stretch: 1;
            spacing: 5px;

            Text {
                text: "系统日志";
                font-size: 10px;
                font-weight: 600;
                color: text-muted;
            }

            Rectangle {
                background: #111827;
                border-radius: 7px;
                border-width: 1px;
                border-color: #1f2d42;
                min-height: 150px;
                clip: true;

                sv := ScrollView {
                    viewport-y <=> log_viewport_y;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 1px;
                        alignment: start;
                        for msg in log_messages: Text {
                            text: "> " + msg;
                            color: #7ec8e3;
                            font-family: "PingFang SC";
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                    }
                }
            }
        }
    }
}
