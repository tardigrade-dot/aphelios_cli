import {
    Button,
    LineEdit,
    ScrollView,
    ProgressIndicator,
} from "std-widgets.slint";

export component TtsWindow inherits Window {
    width: 800px;
    height: 720px;
    title: "Qwen3 TTS";
    background: #eef1f6;
    default-font-family: "PingFang SC";

    in-out property <string> input_text;
    in-out property <int> input_text_length: 0;
    in-out property <string> txt_file_path;
    in-out property <int> txt_line_count: 0;
    in-out property <string> model_path;
    in-out property <string> output_path;
    in-out property <string> ref_audio_path;
    in-out property <string> ref_text;
    in-out property <bool> is_batch_mode: false;
    in-out property <string> status_message: "就绪";
    in-out property <bool> is_running: false;
    in-out property <bool> has_audio: false;
    in-out property <float> progress: 0.0;
    in-out property <[string]> log_messages: ["Session Initialized"];
    in-out property <length> log_viewport_y: 0;
    in-out property <length> input_textViewportY: 0;

    callback scroll_to_bottom();
    scroll_to_bottom => {
        log_viewport_y = -100000px;
    }

    callback text_changed(string);
    callback select_model_path();
    callback select_output_path();
    callback select_ref_audio();
    callback select_txt_file();
    callback start_tts();
    callback start_batch_tts();
    callback play_audio();
    callback go_back();

    VerticalLayout {
        padding: 16px;
        spacing: 14px;
        alignment: start;

        // ── 头部
        HorizontalLayout {
            height: 28px;
            alignment: space-between;

            Button {
                text: "← 返回";
                width: 64px;
                clicked => {
                    root.go_back();
                }
            }

            Text {
                text: "Qwen3 TTS  语音合成中心";
                font-size: 14px;
                font-weight: 700;
                color: #1a2535;
                vertical-alignment: center;
            }

            Rectangle {
                width: 86px;
                height: 20px;
                border-radius: 10px;
                background: is_running ? #1565c0 : #d0d8e4;
                animate background { duration: 250ms; }
                Text {
                    text: status_message;
                    font-size: 11px;
                    font-weight: 600;
                    color: is_running ? #ffffff : #4e5f75;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #d0d8e4;
        }

        // ── 模式切换
        HorizontalLayout {
            alignment: space-between;
            Text {
                text: "合成模式";
                font-size: 11px;
                font-weight: 600;
                color: #6b7a8d;
                vertical-alignment: center;
            }

            Button {
                text: is_batch_mode ? "📄 批量TXT" : "✏️  单段文本";
                width: 120px;
                height: 24px;
                clicked => {
                    root.is_batch_mode = !root.is_batch_mode;
                }
            }
        }

        // ── 批量 TXT 模式
        if is_batch_mode: VerticalLayout {
            spacing: 6px;

            HorizontalLayout {
                alignment: space-between;
                Text {
                    text: "TXT 文件";
                    font-size: 11px;
                    font-weight: 600;
                    color: #6b7a8d;
                    vertical-alignment: center;
                }

                Text {
                    text: txt_line_count > 0 ? txt_line_count + " 行" : "";
                    font-size: 11px;
                    color: #8a9bb0;
                    vertical-alignment: center;
                }
            }

            HorizontalLayout {
                height: 26px;
                spacing: 10px;

                LineEdit {
                    text <=> txt_file_path;
                    font-size: 12px;
                    placeholder-text: "选择 TXT 文件（每行一段）";
                    enabled: !is_running;
                }

                Button {
                    text: "选择";
                    width: 46px;
                    clicked => {
                        root.select_txt_file();
                    }
                }
            }

            HorizontalLayout {
                height: 26px;
                spacing: 10px;
                Text {
                    text: "输出目录";
                    width: 52px;
                    font-size: 12px;
                    color: #1a2535;
                    vertical-alignment: center;
                }

                LineEdit {
                    text <=> output_path;
                    font-size: 12px;
                    placeholder-text: "选择输出目录";
                    enabled: !is_running;
                }

                Button {
                    text: "选择";
                    width: 46px;
                    clicked => {
                        root.select_output_path();
                    }
                }
            }
        }

        // ── 单段文本模式
        if !is_batch_mode: VerticalLayout {
            spacing: 6px;

            HorizontalLayout {
                alignment: space-between;
                Text {
                    text: "待合成文本";
                    font-size: 11px;
                    font-weight: 600;
                    color: #6b7a8d;
                    vertical-alignment: center;
                }

                Text {
                    text: input_text_length + " / 200 字";
                    font-size: 11px;
                    color: input_text_length > 200 ? #e53935 : #8a9bb0;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                background: input_text_length > 200 ? #fff8e1 : #e4e9f0;
                border-radius: 6px;
                height: 68px;
                clip: true;
                animate background { duration: 200ms; }

                input_sv := ScrollView {
                    viewport-y <=> input_textViewportY;
                    VerticalLayout {
                        padding: 8px;
                        alignment: start;
                        TextInput {
                            text <=> input_text;
                            wrap: TextWrap.word-wrap;
                            color: #1a2535;
                            font-size: 13px;
                            enabled: !is_running;
                            edited => {
                                root.text_changed(self.text);
                            }
                        }
                    }
                }
            }

            if input_text_length > 200: Text {
                text: "⚠  建议限制在 200 字以内以获得最佳合成效果";
                color: #ffb300;
                font-size: 10px;
            }
        }

        Rectangle {
            height: 1px;
            background: #d0d8e4;
        }

        // ── 路径配置
        VerticalLayout {
            spacing: 8px;

            Text {
                text: "📂  路径配置";
                font-size: 11px;
                font-weight: 600;
                color: #6b7a8d;
            }

            HorizontalLayout {
                height: 26px;
                spacing: 10px;
                Text {
                    text: "模型路径";
                    width: 52px;
                    font-size: 12px;
                    color: #1a2535;
                    vertical-alignment: center;
                }

                LineEdit {
                    text <=> model_path;
                    font-size: 12px;
                    enabled: !is_running;
                }

                Button {
                    text: "选择";
                    width: 46px;
                    clicked => {
                        root.select_model_path();
                    }
                }
            }

            HorizontalLayout {
                height: 26px;
                spacing: 10px;
                Text {
                    text: "输出路径";
                    width: 52px;
                    font-size: 12px;
                    color: #1a2535;
                    vertical-alignment: center;
                }

                LineEdit {
                    text <=> output_path;
                    font-size: 12px;
                    enabled: !is_running;
                }

                Button {
                    text: "选择";
                    width: 46px;
                    clicked => {
                        root.select_output_path();
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #d0d8e4;
        }

        // ── 语音克隆
        VerticalLayout {
            spacing: 8px;

            HorizontalLayout {
                spacing: 6px;
                Text {
                    text: "🧬  语音克隆";
                    font-size: 11px;
                    font-weight: 600;
                    color: #6b7a8d;
                    vertical-alignment: center;
                }

                Text {
                    text: "Optional";
                    font-size: 10px;
                    color: #b0bec5;
                    vertical-alignment: center;
                }
            }

            HorizontalLayout {
                height: 26px;
                spacing: 10px;
                Text {
                    text: "参考音频";
                    width: 52px;
                    font-size: 12px;
                    color: #1a2535;
                    vertical-alignment: center;
                }

                LineEdit {
                    text <=> ref_audio_path;
                    font-size: 12px;
                    enabled: !is_running;
                }

                Button {
                    text: "选择";
                    width: 46px;
                    clicked => {
                        root.select_ref_audio();
                    }
                }
            }

            HorizontalLayout {
                height: 26px;
                spacing: 10px;
                Text {
                    text: "参考文本";
                    width: 52px;
                    font-size: 12px;
                    color: #1a2535;
                    vertical-alignment: center;
                }

                LineEdit {
                    text <=> ref_text;
                    font-size: 12px;
                    placeholder-text: "音频对应的文字内容";
                    enabled: !is_running;
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #d0d8e4;
        }

        // ── 进度（运行时）
        if is_running: HorizontalLayout {
            height: 16px;
            spacing: 10px;
            ProgressIndicator {
                progress: progress;
                height: 4px;
                horizontal-stretch: 1;
            }

            Text {
                text: Math.round(progress * 100) + "%";
                font-size: 11px;
                font-weight: 600;
                color: #1565c0;
                width: 32px;
                horizontal-alignment: right;
                vertical-alignment: center;
            }
        }

        // ── 操作按钮
        HorizontalLayout {
            alignment: center;
            spacing: 12px;
            height: 34px;

            // 单段模式按钮
            if !is_batch_mode: Button {
                text: is_running ? "合成中…" : "▶  开始合成";
                primary: true;
                width: 136px;
                height: 32px;
                enabled: input_text != "" && !is_running;
                clicked => {
                    root.start_tts();
                }
            }

            // 批量模式按钮
            if is_batch_mode: Button {
                text: is_running ? "合成中…" : "▶  批量合成";
                primary: true;
                width: 136px;
                height: 32px;
                enabled: txt_file_path != "" && !is_running;
                clicked => {
                    root.start_batch_tts();
                }
            }

            Button {
                text: "🔊  播放音频";
                width: 108px;
                height: 32px;
                enabled: has_audio && !is_running;
                clicked => {
                    root.play_audio();
                }
            }
        }

        // ── 系统日志
        VerticalLayout {
            vertical-stretch: 1;
            spacing: 5px;

            Text {
                text: "系统日志";
                font-size: 10px;
                font-weight: 600;
                color: #8a9bb0;
            }

            Rectangle {
                background: #111827;
                border-radius: 7px;
                border-width: 1px;
                border-color: #1f2d42;
                min-height: 150px;
                clip: true;

                sv := ScrollView {
                    viewport-y <=> log_viewport_y;
                    VerticalLayout {
                        padding: 10px;
                        spacing: 1px;
                        alignment: start;
                        for msg in log_messages: Text {
                            text: "> " + msg;
                            color: #7ec8e3;
                            font-family: "PingFang SC";
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                    }
                }
            }
        }
    }
}
